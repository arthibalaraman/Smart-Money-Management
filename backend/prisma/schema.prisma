generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int         @id @default(autoincrement())
  username  String      @unique
  email     String      @unique
  password  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt
  expenses  Expense[]
  forms     Form[]
}

model Expense {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  amount    Float
  category  String
  date      String
  type      String   @default("EXPENSE")
  unit      String   @default("₹")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Form {
  id        Int         @id @default(autoincrement())
  userId    Int
  name      String
  fields    String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   FormEntry[]
}

model FormEntry {
  id        Int      @id @default(autoincrement())
  formId    Int
  data      String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
}
